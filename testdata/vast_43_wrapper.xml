<?xml version="1.0" encoding="UTF-8"?>
<!--
  Comprehensive VAST 4.3 Wrapper document.

  Broadly exercises the Wrapper branch of the VAST 4.3 human-readable schema (spec
  section 5): the wrapper attributes (followAdditionalWrappers, allowMultipleAds,
  fallbackOnNoAd), <VASTAdTagURI>, <ViewableImpression>, <AdVerifications> with
  <BlockedAdCategories>, and wrapped Linear / NonLinear / Companion creatives.
-->
<VAST version="4.3" xmlns="http://www.iab.com/VAST">
  <Ad id="20002" adType="video">
    <Wrapper followAdditionalWrappers="false" allowMultipleAds="true" fallbackOnNoAd="false">
      <AdSystem version="4.3">iabtechlab</AdSystem>
      <Error><![CDATA[https://example.com/track/error/[ERRORCODE]]]></Error>
      <Extensions>
        <Extension type="iab-Count">
          <CustomTracking>
            <Tracking event="interactiveStart"><![CDATA[https://example.com/track/interactiveStart]]></Tracking>
          </CustomTracking>
        </Extension>
      </Extensions>
      <Impression id="Impression-ID"><![CDATA[https://example.com/track/impression]]></Impression>
      <Pricing model="cpm" currency="USD"><![CDATA[25.00]]></Pricing>
      <ViewableImpression id="viewable-impression-id">
        <Viewable><![CDATA[https://example.com/track/viewable]]></Viewable>
        <NotViewable><![CDATA[https://example.com/track/notViewable]]></NotViewable>
        <ViewUndetermined><![CDATA[https://example.com/track/viewUndetermined]]></ViewUndetermined>
      </ViewableImpression>
      <AdVerifications>
        <Verification vendor="company.com-omid">
          <ExecutableResource apiFramework="omid" type="no-op"><![CDATA[https://verificationcompany1.com/executable_resource]]></ExecutableResource>
          <JavaScriptResource apiFramework="omid" browserOptional="true"><![CDATA[https://verificationcompany1.com/verification_script1.js]]></JavaScriptResource>
          <TrackingEvents>
            <Tracking event="verificationNotExecuted"><![CDATA[https://verificationcompany1.com/tracking/verificationNotExecuted]]></Tracking>
          </TrackingEvents>
          <VerificationParameters><![CDATA[{"key":"value"}]]></VerificationParameters>
        </Verification>
      </AdVerifications>
      <BlockedAdCategories authority="https://www.iabtechlab.com/categoryauthority">gambling</BlockedAdCategories>
      <Creatives>
        <Creative id="5490" sequence="1" adId="2447230">
          <Linear>
            <Icons>
              <Icon program="AdChoices" width="60" height="20" xPosition="right" yPosition="top" offset="00:00:00" duration="00:00:16" apiFramework="omid" pxratio="1">
                <StaticResource creativeType="image/png"><![CDATA[https://example.com/icon/adchoices.png]]></StaticResource>
                <IconClicks>
                  <IconClickThrough><![CDATA[https://example.com/icon/clickThrough]]></IconClickThrough>
                  <IconClickTracking id="wrapper-icon-click-tracking"><![CDATA[https://example.com/track/iconClick]]></IconClickTracking>
                </IconClicks>
              </Icon>
            </Icons>
            <TrackingEvents>
              <Tracking event="start"><![CDATA[https://example.com/track/wrapper/start]]></Tracking>
              <Tracking event="complete"><![CDATA[https://example.com/track/wrapper/complete]]></Tracking>
            </TrackingEvents>
            <VideoClicks>
              <ClickTracking id="wrapper-click-tracking"><![CDATA[https://example.com/track/wrapper/clickThrough]]></ClickTracking>
              <ClickThrough id="wrapper-click-through"><![CDATA[https://example.com/wrapper/clickThrough]]></ClickThrough>
              <CustomClick id="wrapper-custom-click"><![CDATA[https://example.com/track/wrapper/customClick]]></CustomClick>
            </VideoClicks>
          </Linear>
        </Creative>
        <Creative id="5491" sequence="2" adId="2447231">
          <NonLinearAds>
            <TrackingEvents>
              <Tracking event="creativeView"><![CDATA[https://example.com/track/wrapper/nonlinearCreativeView]]></Tracking>
            </TrackingEvents>
            <NonLinear>
              <NonLinearClickTracking><![CDATA[https://example.com/track/wrapper/nonlinearClick]]></NonLinearClickTracking>
            </NonLinear>
          </NonLinearAds>
        </Creative>
        <Creative id="5492" sequence="3" adId="2447232">
          <CompanionAds required="any">
            <Companion id="wrapper-companion-1" width="300" height="250">
              <StaticResource creativeType="image/png"><![CDATA[https://example.com/companion/300x250.png]]></StaticResource>
              <CompanionClickThrough><![CDATA[https://example.com/companion/clickThrough]]></CompanionClickThrough>
              <CompanionClickTracking id="wrapper-companion-click-tracking"><![CDATA[https://example.com/track/wrapper/companionClick]]></CompanionClickTracking>
              <TrackingEvents>
                <Tracking event="creativeView"><![CDATA[https://example.com/track/wrapper/companionCreativeView]]></Tracking>
              </TrackingEvents>
            </Companion>
          </CompanionAds>
        </Creative>
      </Creatives>
      <VASTAdTagURI><![CDATA[https://example.com/vast/secondary.xml]]></VASTAdTagURI>
    </Wrapper>
  </Ad>
</VAST>
